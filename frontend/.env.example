# FlakyOllama Frontend Configuration

# URL of the Balancer API. 
# In development (Vite), this is also used as the proxy target.
# If empty, relative paths are used (works if frontend is served by the balancer).
VITE_BALANCER_URL=http://localhost:8080

# Bearer token for authentication with the balancer.
VITE_BALANCER_TOKEN=your-secret-balancer-token
